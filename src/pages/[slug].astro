---
import { getCollection } from 'astro:content';
import MainLayout from '../layouts/MainLayout.astro';
import QuoteForm from '../components/QuoteForm.astro';

export async function getStaticPaths() {
  const productEntries = await getCollection('products');
  return productEntries.map(entry => ({
    params: { slug: entry.data.seoSlug }, props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

const { title, description, h1, category, keywords } = entry.data;
const phone = import.meta.env.PUBLIC_WHATSAPP_PHONE;
---

<MainLayout title={title} description={description}>
  <section class="relative overflow-hidden pt-32 pb-18">
    <div class="absolute inset-x-0 top-0 -z-10 h-[32rem] bg-[radial-gradient(circle_at_top_right,rgba(25,124,177,0.15),transparent_35%),linear-gradient(180deg,#fdfbf8_0%,#f1ece3_100%)] dark:bg-[radial-gradient(circle_at_top_right,rgba(25,124,177,0.20),transparent_35%),linear-gradient(180deg,#071624_0%,#0b1d2d_100%)]"></div>
    
    <div class="section-shell">
      <div class="space-y-6 max-w-4xl">
        <nav class="flex items-center gap-2 text-sm font-medium text-[var(--color-text-muted)] mb-8">
          <a href="/" class="hover:text-[var(--color-brand-primary)]">Inicio</a>
          <span class="text-[var(--color-border)]">/</span>
          <span class="text-[var(--color-brand-secondary)]">{category}</span>
        </nav>
        
        <span class="eyebrow">Solución Industrial MG</span>
        <h1 class="section-title text-4xl md:text-5xl lg:text-6xl">{h1}</h1>
        <p class="section-copy text-lg md:text-xl">
          {description}
        </p>
        
        <div class="flex flex-wrap gap-2 pt-4">
          {keywords.map(kw => (
            <span class="px-3 py-1 rounded-full border border-[var(--color-border)] bg-white/50 dark:bg-white/5 text-xs font-medium text-[var(--color-text-muted)]">
              {kw}
            </span>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 bg-white/30 dark:bg-black/5">
    <div class="section-shell">
      <div class="grid gap-12 lg:grid-cols-[1.2fr_0.8fr]">
        <div class="prose prose-lg dark:prose-invert max-w-none 
          prose-headings:text-[var(--color-brand-primary)] 
          prose-h2:text-3xl prose-h2:font-semibold prose-h2:mt-12 prose-h2:mb-6
          prose-p:text-[var(--color-text-muted)] prose-p:leading-8
          prose-li:text-[var(--color-text-muted)]
          prose-strong:text-[var(--color-brand-primary)]">
          <Content />
        </div>
        
        <aside class="space-y-8">
          <div class="panel p-8 bg-[var(--color-brand-primary)] text-white">
            <h3 class="text-2xl font-semibold mb-4">Cotización técnica en <span class="text-[var(--color-brand-secondary)]">24 horas</span></h3>
            <p class="text-white/80 text-sm leading-7 mb-6">
              En MG entendemos la urgencia del sector industrial y de carrocerías. Si tiene el plano o las medidas, podemos responder rápidamente.
            </p>
            <div class="space-y-4">
              <a href="#cotizar" class="button-secondary w-full text-center py-4 bg-white text-[var(--color-brand-primary)] hover:bg-white/90">
                Solicitar Cotización
              </a>
              <a href={`https://wa.me/${phone}?text=Hola%20MG,%20necesito%20cotizar%20${h1}`} class="flex items-center justify-center gap-2 text-sm font-semibold text-white hover:text-white/80 transition-colors">
                <span>Hablar por WhatsApp</span>
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              </a>
            </div>
          </div>
          
          <div class="panel p-8 surface-card border border-[var(--color-border)]">
            <h3 class="text-xl font-semibold text-[var(--color-brand-primary)] mb-4">Capacidades Destacadas</h3>
            <ul class="space-y-4 text-sm text-[var(--color-text-muted)]">
              <li class="flex items-start gap-3">
                <span class="text-[var(--color-brand-secondary)] font-bold">✓</span>
                <span>Corte de lámina hasta 6 mm de espesor.</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-[var(--color-brand-secondary)] font-bold">✓</span>
                <span>Doblado CNC de precisión hasta 12 mm.</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-[var(--color-brand-secondary)] font-bold">✓</span>
                <span>Longitudes de trabajo hasta 3.2 metros.</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-[var(--color-brand-secondary)] font-bold">✓</span>
                <span>Experiencia real en piezas para furgones y agroindustria.</span>
              </li>
            </ul>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <QuoteForm 
    title={`Cotizar fabricación de ${h1.toLowerCase()}`}
    intro={`Envíenos los detalles de su requerimiento de ${h1.toLowerCase()} y le responderemos con una propuesta técnica y comercial en tiempo récord.`}
  />
</MainLayout>
