---
import MainLayout from '../../layouts/MainLayout.astro';
import QuoteForm from '../../components/QuoteForm.astro';

const solutions = [
  'Tolvas y embudos para manejo de granos',
  'Canales y ductos de conduccion',
  'Guardas de seguridad para maquinaria',
  'Estructuras para secado y almacenamiento',
  'Bandejas recolectoras, soportes y cubiertas',
];

const values = [
  {
    title: 'Resistencia y funcionalidad',
    description: 'Pensado para piezas que deben responder al trabajo real de planta o campo, no solo verse bien en plano.',
  },
  {
    title: 'Desarrollos a medida',
    description: 'Fabricamos segun dimensiones, material, flujo y contexto operativo del cliente.',
  },
  {
    title: 'Integracion con proceso',
    description: 'Combinamos corte y doblado para resolver piezas mas utiles para conduccion, soporte y almacenamiento.',
  },
];
---

<MainLayout
  title="Agroindustria | MG Cortes & Dobleces"
  description="Soluciones metalicas para agroindustria en Santander. Tolvas, ductos, cubiertas, soportes y piezas a medida con corte y doblado CNC."
>
  <section class="relative overflow-hidden pt-32 pb-18">
    <div class="absolute inset-x-0 top-0 -z-10 h-[30rem] bg-[radial-gradient(circle_at_top_left,rgba(25,124,177,0.18),transparent_30%),linear-gradient(180deg,#fdfbf8_0%,#f1ece3_100%)] dark:bg-[radial-gradient(circle_at_top_left,rgba(25,124,177,0.20),transparent_25%),linear-gradient(180deg,#071624_0%,#0b1d2d_100%)]"></div>
    <div class="section-shell grid gap-10 lg:grid-cols-[1fr_0.95fr]">
      <div class="space-y-6">
        <span class="eyebrow">Sector agroindustria</span>
        <h1 class="section-title max-w-4xl">Soluciones metalicas para agroindustria con enfoque en resistencia, funcionalidad y respuesta tecnica</h1>
        <p class="section-copy">
          Desarrollamos tolvas, ductos, cubiertas, soportes y piezas metalicas a medida para operaciones que necesitan componentes utiles, bien resueltos y adaptados a condiciones reales de trabajo.
        </p>
        <div class="flex flex-col gap-4 sm:flex-row">
          <a href="/cotizar" class="button-primary">Solicitar cotizacion</a>
          <a href="/soluciones/tolvas-ductos-y-canales" class="button-secondary">Ver soluciones relacionadas</a>
        </div>
      </div>
      <div class="panel p-7">
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-[var(--color-brand-secondary)]">Dolor que resolvemos</p>
        <div class="mt-5 rounded-[1.2rem] bg-[var(--color-brand-primary)] p-6 text-white">
          <h2 class="text-2xl font-semibold">Piezas o desarrollos que deben soportar operacion, flujo y uso continuo</h2>
          <p class="mt-3 text-sm text-white/76">
            Ayudamos a fabricar componentes que respondan mejor a necesidades de conduccion, soporte, descarga y proteccion dentro del proceso agroindustrial.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20">
    <div class="section-shell grid gap-6 md:grid-cols-2">
      <article class="panel p-7">
        <span class="eyebrow">Requerimientos frecuentes</span>
        <ul class="mt-5 space-y-3 text-sm text-[var(--color-text-muted)]">
          {solutions.map((solution) => <li>{solution}</li>)}
        </ul>
      </article>
      <article class="panel p-7">
        <span class="eyebrow">Soluciones relacionadas</span>
        <div class="mt-5 space-y-3 text-sm text-[var(--color-text-muted)]">
          <p><a href="/soluciones/tolvas-ductos-y-canales" class="font-semibold text-[var(--color-brand-primary)]">Tolvas, ductos y canales</a></p>
          <p><a href="/soluciones/piezas-bajo-plano" class="font-semibold text-[var(--color-brand-primary)]">Piezas metalicas bajo plano</a></p>
          <p><a href="/servicios/corte-cnc-lamina" class="font-semibold text-[var(--color-brand-primary)]">Corte CNC de lamina</a></p>
          <p><a href="/servicios/doblado-cnc-lamina" class="font-semibold text-[var(--color-brand-primary)]">Doblado CNC de lamina</a></p>
        </div>
      </article>
    </div>
  </section>

  <section class="py-20">
    <div class="section-shell space-y-8">
      <div class="space-y-4">
        <span class="eyebrow">Lo que mas valora este sector</span>
        <h2 class="section-title">Una respuesta pensada para procesos donde el material debe fluir, resistir y encajar</h2>
      </div>
      <div class="grid gap-6 md:grid-cols-3">
        {values.map((value) => (
          <article class="panel p-7">
            <h3 class="text-2xl font-semibold text-[var(--color-brand-primary)]">{value.title}</h3>
            <p class="mt-4 text-sm text-[var(--color-text-muted)]">{value.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <QuoteForm
    title="Solicita cotizacion para agroindustria"
    intro="Comparte tipo de desarrollo, dimensiones, material, uso final y fecha requerida para ayudarte a responder con mejor criterio tecnico."
  />
</MainLayout>
