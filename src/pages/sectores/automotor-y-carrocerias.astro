---
import MainLayout from '../../layouts/MainLayout.astro';
import QuoteForm from '../../components/QuoteForm.astro';

const needs = [
  'Defensas y bigotes metalicos',
  'Enchapes y pisos plisados',
  'Guardabarros y guardapolvos',
  'Cajas de herramientas y acabados especiales',
  'Componentes metalicos para furgones y carrocerias',
];

const promises = [
  {
    title: 'Piezas consistentes',
    description: 'Buscamos repetibilidad y mejor ajuste para que el trabajo no se frene en montaje o reparacion.',
  },
  {
    title: 'Lectura tecnica del requerimiento',
    description: 'Entendemos mejor la necesidad de taller, no solo la orden de compra.',
  },
  {
    title: 'Tiempo de respuesta',
    description: 'Cotizacion agil y enfoque en entregas que no afecten cronogramas de produccion o despacho.',
  },
];
---

<MainLayout
  title="Automotor y carrocerias | MG Cortes & Dobleces"
  description="Soluciones metalicas para automotor y carrocerias en Santander. Defensas, bigotes, enchapes y piezas repetibles con corte y doblado CNC."
>
  <section class="relative overflow-hidden pt-32 pb-18">
    <div class="absolute inset-x-0 top-0 -z-10 h-[30rem] bg-[radial-gradient(circle_at_top_right,rgba(25,124,177,0.18),transparent_30%),linear-gradient(180deg,#fdfbf8_0%,#f1ece3_100%)] dark:bg-[radial-gradient(circle_at_top_right,rgba(25,124,177,0.20),transparent_25%),linear-gradient(180deg,#071624_0%,#0b1d2d_100%)]"></div>
    <div class="section-shell grid gap-10 lg:grid-cols-[1fr_0.95fr]">
      <div class="space-y-6">
        <span class="eyebrow">Sector principal</span>
        <h1 class="section-title max-w-4xl">Soluciones metalicas para automotor y carrocerias con enfoque en tiempo, repetibilidad y montaje</h1>
        <p class="section-copy">
          Este es hoy el mercado mas fuerte de MG. Atendemos talleres y operaciones de carrocerias que necesitan piezas bien resueltas, listas para ensamble y con tiempos que no afecten reparaciones, despachos o fabricacion.
        </p>
        <div class="flex flex-col gap-4 sm:flex-row">
          <a href="/cotizar" class="button-primary">Solicitar cotizacion</a>
          <a href="/soluciones/defensas-y-componentes-para-carrocerias" class="button-secondary">Ver soluciones relacionadas</a>
        </div>
      </div>
      <div class="panel p-7">
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-[var(--color-brand-secondary)]">Dolor que resolvemos</p>
        <div class="mt-5 rounded-[1.2rem] bg-[var(--color-brand-primary)] p-6 text-white">
          <h2 class="text-2xl font-semibold">Evitar atrasos por piezas inconsistentes o entregas tardias</h2>
          <p class="mt-3 text-sm text-white/76">
            Ayudamos a reducir retrabajo, esperas y fricciones en ensamble con piezas mejor pensadas para la realidad del taller o la operacion.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20">
    <div class="section-shell grid gap-6 md:grid-cols-2">
      <article class="panel p-7">
        <span class="eyebrow">Requerimientos frecuentes</span>
        <ul class="mt-5 space-y-3 text-sm text-[var(--color-text-muted)]">
          {needs.map((need) => <li>{need}</li>)}
        </ul>
      </article>
      <article class="panel p-7">
        <span class="eyebrow">Soluciones relacionadas</span>
        <div class="mt-5 space-y-3 text-sm text-[var(--color-text-muted)]">
          <p><a href="/soluciones/defensas-y-componentes-para-carrocerias" class="font-semibold text-[var(--color-brand-primary)]">Defensas y componentes para carrocerias</a></p>
          <p><a href="/soluciones/piezas-bajo-plano" class="font-semibold text-[var(--color-brand-primary)]">Piezas metalicas bajo plano</a></p>
          <p><a href="/servicios/corte-cnc-lamina" class="font-semibold text-[var(--color-brand-primary)]">Corte CNC de lamina</a></p>
          <p><a href="/servicios/doblado-cnc-lamina" class="font-semibold text-[var(--color-brand-primary)]">Doblado CNC de lamina</a></p>
        </div>
      </article>
    </div>
  </section>

  <section class="py-20">
    <div class="section-shell space-y-8">
      <div class="space-y-4">
        <span class="eyebrow">Lo que mas valora este sector</span>
        <h2 class="section-title">Una respuesta pensada para talleres que trabajan con compromisos de entrega</h2>
      </div>
      <div class="grid gap-6 md:grid-cols-3">
        {promises.map((promise) => (
          <article class="panel p-7">
            <h3 class="text-2xl font-semibold text-[var(--color-brand-primary)]">{promise.title}</h3>
            <p class="mt-4 text-sm text-[var(--color-text-muted)]">{promise.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <QuoteForm
    title="Solicita cotizacion para carrocerias y componentes automotor"
    intro="Comparte tipo de pieza, referencia, cantidades y fecha requerida para ayudarte a responder mas rapido y con mejor criterio tecnico."
  />
</MainLayout>
