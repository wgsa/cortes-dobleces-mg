---
import MainLayout from '../../layouts/MainLayout.astro';
import QuoteForm from '../../components/QuoteForm.astro';

const solutions = [
  'Formaletas metalicas',
  'Canales y bajantes',
  'Perfiles estructurales en L, U y omegas',
  'Cubiertas y remates metalicos',
  'Escaleras, barandas y cerramientos',
];

const values = [
  {
    title: 'Cumplimiento dimensional',
    description: 'Piezas que ayudan a reducir ajustes innecesarios en instalacion o montaje.',
  },
  {
    title: 'Apoyo a cronogramas',
    description: 'Respuesta comercial pensada para no afectar el avance de obra o la programacion del contratista.',
  },
  {
    title: 'Desarrollos funcionales',
    description: 'Fabricamos componentes utiles para estructura, cerramiento, soporte y acabados metalicos.',
  },
];
---

<MainLayout
  title="Construccion | MG Cortes & Dobleces"
  description="Soluciones metalicas para construccion en Santander. Formaletas, perfiles, canales, bajantes, cubiertas y remates con corte y doblado CNC."
>
  <section class="relative overflow-hidden pt-32 pb-18">
    <div class="absolute inset-x-0 top-0 -z-10 h-[30rem] bg-[radial-gradient(circle_at_top_right,rgba(25,124,177,0.18),transparent_30%),linear-gradient(180deg,#fdfbf8_0%,#f1ece3_100%)] dark:bg-[radial-gradient(circle_at_top_right,rgba(25,124,177,0.20),transparent_25%),linear-gradient(180deg,#071624_0%,#0b1d2d_100%)]"></div>
    <div class="section-shell grid gap-10 lg:grid-cols-[1fr_0.95fr]">
      <div class="space-y-6">
        <span class="eyebrow">Sector construccion</span>
        <h1 class="section-title max-w-4xl">Soluciones metalicas para construccion con enfoque en cumplimiento y funcionalidad</h1>
        <p class="section-copy">
          Fabricamos componentes metalicos para proyectos de infraestructura, instalaciones y contratistas que necesitan piezas confiables, bien medidas y alineadas con el cronograma de obra.
        </p>
        <div class="flex flex-col gap-4 sm:flex-row">
          <a href="/cotizar" class="button-primary">Solicitar cotizacion</a>
          <a href="/soluciones/piezas-bajo-plano" class="button-secondary">Ver soluciones relacionadas</a>
        </div>
      </div>
      <div class="panel p-7">
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-[var(--color-brand-secondary)]">Dolor que resolvemos</p>
        <div class="mt-5 rounded-[1.2rem] bg-[var(--color-brand-primary)] p-6 text-white">
          <h2 class="text-2xl font-semibold">Piezas que no pueden llegar tarde ni requerir demasiado ajuste en obra</h2>
          <p class="mt-3 text-sm text-white/76">
            Apoyamos proyectos donde el tiempo, la medida y el orden de instalacion tienen impacto directo en el avance del trabajo.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20">
    <div class="section-shell grid gap-6 md:grid-cols-2">
      <article class="panel p-7">
        <span class="eyebrow">Requerimientos frecuentes</span>
        <ul class="mt-5 space-y-3 text-sm text-[var(--color-text-muted)]">
          {solutions.map((solution) => <li>{solution}</li>)}
        </ul>
      </article>
      <article class="panel p-7">
        <span class="eyebrow">Servicios relacionados</span>
        <div class="mt-5 space-y-3 text-sm text-[var(--color-text-muted)]">
          <p><a href="/servicios/corte-cnc-lamina" class="font-semibold text-[var(--color-brand-primary)]">Corte CNC de lamina</a></p>
          <p><a href="/servicios/doblado-cnc-lamina" class="font-semibold text-[var(--color-brand-primary)]">Doblado CNC de lamina</a></p>
          <p><a href="/soluciones/piezas-bajo-plano" class="font-semibold text-[var(--color-brand-primary)]">Piezas metalicas bajo plano</a></p>
        </div>
      </article>
    </div>
  </section>

  <section class="py-20">
    <div class="section-shell space-y-8">
      <div class="space-y-4">
        <span class="eyebrow">Lo que mas valora este sector</span>
        <h2 class="section-title">Una respuesta pensada para instalacion, avance de obra y cumplimiento dimensional</h2>
      </div>
      <div class="grid gap-6 md:grid-cols-3">
        {values.map((value) => (
          <article class="panel p-7">
            <h3 class="text-2xl font-semibold text-[var(--color-brand-primary)]">{value.title}</h3>
            <p class="mt-4 text-sm text-[var(--color-text-muted)]">{value.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <QuoteForm
    title="Solicita cotizacion para construccion e infraestructura"
    intro="Comparte plano, tipo de pieza, cantidades y fecha requerida para ayudarte a responder con una cotizacion mas util para tu cronograma."
  />
</MainLayout>
